# Django Settings
SECRET_KEY=your-secret-key-here-generate-new-one
DEBUG=False
ALLOWED_HOSTS=janhelps.in,www.janhelps.in,.vercel.app
CSRF_TRUSTED_ORIGINS=https://janhelps.in,https://www.janhelps.in,https://*.vercel.app

# Base URL
BASE_URL=https://janhelps.in

# Database (Supabase PostgreSQL)
# Get your connection string from Supabase project settings
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Cloudinary Storage Settings
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (Resend - Recommended)
RESEND_API_KEY=your-resend-api-key
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@janhelps.in

# Fallback SMTP (if not using Resend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# SMS Configuration (Optional)
SMS_BACKEND=console
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=your-twilio-number

# MapmyIndia (Mappls) API Key
# Get your API key from: https://apis.mappls.com/console/
MAPPLE_API_KEY=your-mapmyindia-api-key-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# CityFix LLM API
CITYFIX_LLM_URL=https://kartik1911-cityfix-llm.hf.space

# Redis Cache (Optional - for production)
REDIS_URL=redis://your-redis-url:6379
