# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-new-one
DEBUG=False
ALLOWED_HOSTS=janhelps.in,www.janhelps.in,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://janhelps.in,https://www.janhelps.in
BASE_URL=https://janhelps.in

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# ── Cloudinary (Media Storage) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Firebase (Push Notifications + SMS via FCM) ───────────────────────────────
# Download serviceAccountKey.json from Firebase Console → Project Settings → Service Accounts
# Place it at the project root (it is gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@janhelps.in

# Fallback SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── SMS Backend ───────────────────────────────────────────────────────────────
# Options: console | firebase
SMS_BACKEND=firebase

# ── Redis Cache (Optional) ────────────────────────────────────────────────────
REDIS_URL=redis://your-redis-url:6379

# ── MapmyIndia (Mappls) ───────────────────────────────────────────────────────
MAPPLE_API_KEY=your-mapmyindia-api-key-here

# ── CityFix LLM ───────────────────────────────────────────────────────────────
CITYFIX_LLM_URL=https://kartik1911-cityfix-llm.hf.space
